generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTHENTICATION ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  avatar        String?
  role          UserRole  @default(CUSTOMER)
  status        UserStatus @default(ACTIVE)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  customer      Customer?
  admin         Admin?
  sessions      Session[]
  notifications Notification[]

  @@index([email])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ==================== CUSTOMER ====================

model Customer {
  id                String   @id @default(cuid())
  userId            String   @unique
  companyName       String?
  website           String?
  industry          String?
  address           String?
  city              String?
  country           String?
  postalCode        String?
  timezone          String   @default("UTC")
  preferredLanguage String   @default("en")
  lifetimeValue     Decimal  @default(0) @db.Decimal(12, 2)
  totalOrders       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders            Order[]
  bookings          Booking[]
  subscriptions     Subscription[]
  quotes            Quote[]
  supportTickets    SupportTicket[]
  conversations     Conversation[]
  activities        CustomerActivity[]
  notes             CustomerNote[]
  tags              CustomerTag[]
  payments          Payment[]
  invoices          Invoice[]

  @@index([userId])
}

model CustomerActivity {
  id          String       @id @default(cuid())
  customerId  String
  type        ActivityType
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([type])
  @@index([createdAt])
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  authorId   String
  content    String
  isInternal Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model CustomerTag {
  id         String @id @default(cuid())
  customerId String
  tagId      String

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([customerId, tagId])
}

model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  color     String        @default("#6366f1")
  createdAt DateTime      @default(now())

  customers CustomerTag[]

  @@index([name])
}

enum ActivityType {
  ORDER_PLACED
  ORDER_COMPLETED
  BOOKING_MADE
  BOOKING_COMPLETED
  PAYMENT_MADE
  SUBSCRIPTION_STARTED
  SUBSCRIPTION_CANCELLED
  TICKET_OPENED
  TICKET_RESOLVED
  QUOTE_REQUESTED
  QUOTE_ACCEPTED
  LOGIN
  PROFILE_UPDATED
}

// ==================== ADMIN ====================

model Admin {
  id          String   @id @default(cuid())
  userId      String   @unique
  department  String?
  permissions Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================== SERVICES ====================

model ServiceCategory {
  id            String   @id @default(cuid())
  slug          String   @unique
  nameEn        String
  nameAr        String
  descriptionEn String?
  descriptionAr String?
  icon          String?
  image         String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subcategories ServiceSubcategory[]
  services      Service[]

  @@index([slug])
  @@index([isActive])
}

model ServiceSubcategory {
  id            String   @id @default(cuid())
  categoryId    String
  slug          String   @unique
  nameEn        String
  nameAr        String
  descriptionEn String?
  descriptionAr String?
  icon          String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  services Service[]

  @@index([categoryId])
  @@index([slug])
}

model Service {
  id              String       @id @default(cuid())
  categoryId      String
  subcategoryId   String?
  slug            String       @unique
  nameEn          String
  nameAr          String
  shortDescEn     String
  shortDescAr     String
  descriptionEn   String
  descriptionAr   String
  featuresEn      Json
  featuresAr      Json
  type            ServiceType
  image           String?
  gallery         Json?
  isActive        Boolean      @default(true)
  isFeatured      Boolean      @default(false)
  hasBooking      Boolean      @default(false)
  hasSubscription Boolean      @default(false)
  hasCustomQuote  Boolean      @default(false)
  averageRating   Decimal      @default(0) @db.Decimal(3, 2)
  totalReviews    Int          @default(0)
  totalOrders     Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  category      ServiceCategory     @relation(fields: [categoryId], references: [id])
  subcategory   ServiceSubcategory? @relation(fields: [subcategoryId], references: [id])
  pricingTiers  PricingTier[]
  addOns        ServiceAddOn[]
  packages      ServicePackage[]
  bookingConfig BookingConfig?
  subscriptionPlans SubscriptionPlan[]
  orders        Order[]
  bookings      Booking[]
  quotes        Quote[]
  reviews       Review[]

  @@index([categoryId])
  @@index([subcategoryId])
  @@index([slug])
  @@index([type])
  @@index([isActive, isFeatured])
}

model PricingTier {
  id            String   @id @default(cuid())
  serviceId     String
  tier          PricingTierType
  nameEn        String
  nameAr        String
  descriptionEn String?
  descriptionAr String?
  price         Decimal  @db.Decimal(10, 2)
  deliveryDays  Int
  revisions     Int      @default(1)
  featuresEn    Json
  featuresAr    Json
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orders  Order[]

  @@unique([serviceId, tier])
  @@index([serviceId])
}

model ServiceAddOn {
  id            String   @id @default(cuid())
  serviceId     String
  nameEn        String
  nameAr        String
  descriptionEn String?
  descriptionAr String?
  price         Decimal  @db.Decimal(10, 2)
  deliveryDays  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  service     Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orderAddOns OrderAddOn[]

  @@index([serviceId])
}

model ServicePackage {
  id            String   @id @default(cuid())
  serviceId     String
  nameEn        String
  nameAr        String
  descriptionEn String?
  descriptionAr String?
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  includedItems Json
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

enum ServiceType {
  DIGITAL
  AI
  MARKETING
  CONSULTING
  BOOKING
  SUBSCRIPTION
  CUSTOM
}

enum PricingTierType {
  BASIC
  STANDARD
  PREMIUM
}

// ==================== BOOKING ====================

model BookingConfig {
  id                String   @id @default(cuid())
  serviceId         String   @unique
  duration          Int      @default(60)
  bufferTime        Int      @default(15)
  maxAdvanceDays    Int      @default(30)
  minAdvanceHours   Int      @default(24)
  allowedDays       Json
  timezone          String   @default("UTC")
  requiresApproval  Boolean  @default(false)
  cancellationHours Int      @default(24)
  price             Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  service   Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  timeSlots BookingTimeSlot[]

  @@index([serviceId])
}

model BookingTimeSlot {
  id              String   @id @default(cuid())
  bookingConfigId String
  dayOfWeek       Int
  startTime       String
  endTime         String
  maxBookings     Int      @default(1)
  isActive        Boolean  @default(true)

  bookingConfig BookingConfig @relation(fields: [bookingConfigId], references: [id], onDelete: Cascade)
  bookings      Booking[]

  @@index([bookingConfigId])
}

model Booking {
  id            String        @id @default(cuid())
  customerId    String
  serviceId     String
  timeSlotId    String?
  date          DateTime
  startTime     String
  endTime       String
  status        BookingStatus @default(PENDING)
  notes         String?
  meetingLink   String?
  price         Decimal       @db.Decimal(10, 2)
  cancelledAt   DateTime?
  cancelReason  String?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer Customer         @relation(fields: [customerId], references: [id])
  service  Service          @relation(fields: [serviceId], references: [id])
  timeSlot BookingTimeSlot? @relation(fields: [timeSlotId], references: [id])
  payment  Payment?

  @@index([customerId])
  @@index([serviceId])
  @@index([date])
  @@index([status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ==================== SUBSCRIPTION ====================

model SubscriptionPlan {
  id              String            @id @default(cuid())
  serviceId       String
  nameEn          String
  nameAr          String
  descriptionEn   String?
  descriptionAr   String?
  interval        BillingInterval
  intervalCount   Int               @default(1)
  price           Decimal           @db.Decimal(10, 2)
  featuresEn      Json
  featuresAr      Json
  trialDays       Int               @default(0)
  isActive        Boolean           @default(true)
  stripeProductId String?
  stripePriceId   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([serviceId])
}

model Subscription {
  id                   String             @id @default(cuid())
  customerId           String
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  cancelledAt          DateTime?
  cancelReason         String?
  stripeSubscriptionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  customer Customer         @relation(fields: [customerId], references: [id])
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([customerId])
  @@index([planId])
  @@index([status])
}

enum BillingInterval {
  WEEK
  MONTH
  YEAR
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  PAST_DUE
}

// ==================== ORDERS ====================

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String
  serviceId       String
  pricingTierId   String?
  status          OrderStatus @default(PENDING)
  requirements    String?
  deliverables    Json?
  subtotal        Decimal     @db.Decimal(10, 2)
  discount        Decimal     @default(0) @db.Decimal(10, 2)
  tax             Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  deliveryDate    DateTime?
  deliveredAt     DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  revisionsUsed   Int         @default(0)
  revisionsLeft   Int         @default(1)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customer    Customer       @relation(fields: [customerId], references: [id])
  service     Service        @relation(fields: [serviceId], references: [id])
  pricingTier PricingTier?   @relation(fields: [pricingTierId], references: [id])
  addOns      OrderAddOn[]
  revisions   OrderRevision[]
  files       OrderFile[]
  messages    OrderMessage[]
  payment     Payment?
  invoice     Invoice?
  review      Review?

  @@index([orderNumber])
  @@index([customerId])
  @@index([serviceId])
  @@index([status])
  @@index([createdAt])
}

model OrderAddOn {
  id       String  @id @default(cuid())
  orderId  String
  addOnId  String
  price    Decimal @db.Decimal(10, 2)
  quantity Int     @default(1)

  order Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addOn ServiceAddOn @relation(fields: [addOnId], references: [id])

  @@index([orderId])
}

model OrderRevision {
  id          String         @id @default(cuid())
  orderId     String
  number      Int
  request     String
  status      RevisionStatus @default(PENDING)
  response    String?
  files       Json?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderFile {
  id        String   @id @default(cuid())
  orderId   String
  name      String
  url       String
  type      FileType
  size      Int
  uploadedBy String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderMessage {
  id        String   @id @default(cuid())
  orderId   String
  senderId  String
  content   String
  files     Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  IN_REVIEW
  REVISION
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum RevisionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum FileType {
  REQUIREMENT
  DELIVERABLE
  REVISION
  ATTACHMENT
}

// ==================== QUOTES ====================

model Quote {
  id           String      @id @default(cuid())
  quoteNumber  String      @unique
  customerId   String
  serviceId    String
  status       QuoteStatus @default(PENDING)
  requirements String
  budget       Decimal?    @db.Decimal(10, 2)
  timeline     String?
  proposedPrice Decimal?   @db.Decimal(10, 2)
  proposedTimeline String?
  adminNotes   String?
  validUntil   DateTime?
  acceptedAt   DateTime?
  rejectedAt   DateTime?
  rejectReason String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])

  @@index([quoteNumber])
  @@index([customerId])
  @@index([serviceId])
  @@index([status])
}

enum QuoteStatus {
  PENDING
  REVIEWING
  QUOTED
  ACCEPTED
  REJECTED
  EXPIRED
}

// ==================== REVIEWS ====================

model Review {
  id         String   @id @default(cuid())
  orderId    String   @unique
  serviceId  String
  rating     Int
  title      String?
  content    String?
  isVerified Boolean  @default(true)
  isVisible  Boolean  @default(true)
  response   String?
  respondedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([serviceId])
  @@index([rating])
}

// ==================== PAYMENTS ====================

model Payment {
  id              String        @id @default(cuid())
  customerId      String
  orderId         String?       @unique
  bookingId       String?       @unique
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("USD")
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  stripePaymentId String?
  paypalPaymentId String?
  metadata        Json?
  paidAt          DateTime?
  refundedAt      DateTime?
  refundAmount    Decimal?      @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([method])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  customerId     String
  orderId        String?       @unique
  subscriptionId String?
  subtotal       Decimal       @db.Decimal(10, 2)
  discount       Decimal       @default(0) @db.Decimal(10, 2)
  tax            Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer     Customer      @relation(fields: [customerId], references: [id])
  order        Order?        @relation(fields: [orderId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  items        InvoiceItem[]

  @@index([invoiceNumber])
  @@index([customerId])
  @@index([status])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

enum PaymentMethod {
  STRIPE
  PAYPAL
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// ==================== SUPPORT ====================

model SupportTicket {
  id          String       @id @default(cuid())
  ticketNumber String      @unique
  customerId  String
  subject     String
  description String
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus @default(OPEN)
  category    String?
  assignedTo  String?
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  customer  Customer        @relation(fields: [customerId], references: [id])
  messages  TicketMessage[]

  @@index([ticketNumber])
  @@index([customerId])
  @@index([status])
  @@index([priority])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  senderId   String
  senderType SenderType
  content    String
  files      Json?
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Conversation {
  id         String   @id @default(cuid())
  customerId String
  subject    String?
  status     ConversationStatus @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer              @relation(fields: [customerId], references: [id])
  messages ConversationMessage[]

  @@index([customerId])
  @@index([status])
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  senderType     SenderType
  content        String
  files          Json?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
}

enum SenderType {
  CUSTOMER
  ADMIN
  SYSTEM
}

// ==================== CRM / SALES ====================

model Lead {
  id          String     @id @default(cuid())
  email       String
  firstName   String?
  lastName    String?
  phone       String?
  companyName String?
  source      LeadSource
  status      LeadStatus @default(NEW)
  score       Int        @default(0)
  assignedTo  String?
  notes       String?
  convertedAt DateTime?
  customerId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  activities LeadActivity[]

  @@index([email])
  @@index([status])
  @@index([source])
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  type        String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  PAID_ADS
  EMAIL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  ORDER
  BOOKING
  PAYMENT
  SUBSCRIPTION
  SUPPORT
  SYSTEM
}

// ==================== ANALYTICS ====================

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String
  userId    String?
  sessionId String?
  page      String?
  referrer  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([createdAt])
}

model DailyAnalytics {
  id             String   @id @default(cuid())
  date           DateTime @unique @db.Date
  pageViews      Int      @default(0)
  uniqueVisitors Int      @default(0)
  newCustomers   Int      @default(0)
  ordersCount    Int      @default(0)
  ordersRevenue  Decimal  @default(0) @db.Decimal(12, 2)
  bookingsCount  Int      @default(0)
  bookingsRevenue Decimal @default(0) @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([date])
}

// ==================== SETTINGS ====================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([group])
}
